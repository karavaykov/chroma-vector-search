# Chroma Vector Search - Environment Variables
# Copy this file to .env and modify as needed

# Service Ports
API_GATEWAY_PORT=8000
INDEXING_PORT=8001
SEARCH_PORT=8002
METADATA_PORT=8003
CHROMA_PORT=8004
REDIS_PORT=6379
POSTGRES_PORT=5432
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
NGINX_PORT=80
NGINX_SSL_PORT=443

# Database Configuration
POSTGRES_DB=chroma_metadata
POSTGRES_USER=chroma
POSTGRES_PASSWORD=chroma123

# Redis Configuration
REDIS_MAXMEMORY=512mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# Service Resource Limits (Docker)
INDEXING_MEMORY_LIMIT=2G
INDEXING_MEMORY_RESERVATION=1G
INDEXING_CPUS=2
INDEXING_CPUS_RESERVATION=1

SEARCH_MEMORY_LIMIT=1G
SEARCH_MEMORY_RESERVATION=512M
SEARCH_CPUS=1
SEARCH_CPUS_RESERVATION=0.5

METADATA_MEMORY_LIMIT=512M
METADATA_MEMORY_RESERVATION=256M
METADATA_CPUS=1
METADATA_CPUS_RESERVATION=0.5

GATEWAY_MEMORY_LIMIT=512M
GATEWAY_MEMORY_RESERVATION=256M
GATEWAY_CPUS=1
GATEWAY_CPUS_RESERVATION=0.5

# Indexing Configuration
MODEL_CACHE_SIZE=5
BATCH_SIZE=1000
MAX_FILE_SIZE_MB=10
PROJECT_ROOT=/workspace

# Search Configuration
CACHE_TTL_SECONDS=300
MAX_CACHE_SIZE=10000

# Metadata Configuration
METADATA_CACHE_TTL=600

# API Gateway Configuration
RATE_LIMIT_PER_MINUTE=60
REQUEST_TIMEOUT_SECONDS=30
CORS_ORIGINS=*

# Monitoring
GRAFANA_ADMIN_PASSWORD=admin

# Model Configuration
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security (for production)
# JWT_SECRET=your-jwt-secret-key-here
# API_KEY=your-api-key-here
# SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
# SSL_KEY_PATH=/etc/nginx/ssl/key.pem